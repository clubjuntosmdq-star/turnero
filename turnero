    <script>
        let pacientes = JSON.parse(localStorage.getItem('pacientes')) || [];
        let turnos = JSON.parse(localStorage.getItem('turnos')) || [];
        let asistencias = JSON.parse(localStorage.getItem('asistencias')) || [];
        let historias = JSON.parse(localStorage.getItem('historias')) || [];
        let facturas = JSON.parse(localStorage.getItem('facturas')) || [];
        let mensajes = JSON.parse(localStorage.getItem('mensajes')) || [];
        let tareas = JSON.parse(localStorage.getItem('tareas')) || [];
        let pagos = JSON.parse(localStorage.getItem('pagos')) || [];

        // INICIALIZAR
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('turn-fecha').valueAsDate = new Date();
            document.getElementById('asi-fecha').valueAsDate = new Date();
            document.getElementById('fact-per').value = new Date().toISOString().slice(0, 7);
            document.getElementById('pago-fecha').valueAsDate = new Date();

            cargarSelects();
            actualizarDashboard();
            actualizarTablas();
        });

        // FUNCIONES DE NAVEGACIÓN
        function showModule(name) {
            document.querySelectorAll('.module').forEach(m => m.classList.remove('active'));
            document.getElementById(name).classList.add('active');

            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            event.target.classList.add('active');

            actualizarTablas();
            actualizarDashboard();
        }

        // CARGAR SELECTS
        function cargarSelects() {
            const selects = ['turn-pac', 'asi-pac', 'his-pac', 'fact-pac', 'msg-pac', 'tarea-pac', 'pago-pac'];
            selects.forEach(id => {
                const select = document.getElementById(id);
                select.innerHTML = '<option value="">Seleccionar...</option>';
                pacientes.forEach(p => {
                    const opt = document.createElement('option');
                    opt.value = p.id;
                    opt.text = p.nombre;
                    select.appendChild(opt);
                });
            });
        }

        // PACIENTES
        function agregarPaciente() {
            const nombre = document.getElementById('pac-nombre').value;
            const dni = document.getElementById('pac-dni').value;
            const tel = document.getElementById('pac-tel').value;
            const email = document.getElementById('pac-email').value;
            const os = document.getElementById('pac-os').value;
            const afil = document.getElementById('pac-afil').value;

            if (!nombre || !dni) {
                alert('Completa nombre y DNI');
                return;
            }

            pacientes.push({
                id: Date.now(),
                nombre,
                dni,
                tel,
                email,
                os,
                afil
            });

            localStorage.setItem('pacientes', JSON.stringify(pacientes));
            limpiarFormPaciente();
            cargarSelects();
            actualizarTablas();
            actualizarDashboard();
            mostrarNotificacion('✓ Paciente registrado', 'success');
        }

        function limpiarFormPaciente() {
            document.getElementById('pac-nombre').value = '';
            document.getElementById('pac-dni').value = '';
            document.getElementById('pac-tel').value = '';
            document.getElementById('pac-email').value = '';
            document.getElementById('pac-os').value = '';
            document.getElementById('pac-afil').value = '';
        }

        // TURNOS
        function agregarTurno() {
            const pac = document.getElementById('turn-pac').value;
            const fecha = document.getElementById('turn-fecha').value;
            const hora = document.getElementById('turn-hora').value;
            const prof = document.getElementById('turn-prof').value;
            const serv = document.getElementById('turn-serv').value;
            const est = document.getElementById('turn-est').value;

            if (!pac || !fecha || !hora || !prof || !serv) {
                alert('Completa todos los campos obligatorios');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            turnos.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                fecha,
                hora,
                profesional: prof,
                servicio: serv,
                estado: est
            });

            localStorage.setItem('turnos', JSON.stringify(turnos));
            limpiarFormTurno();
            actualizarTablas();
            actualizarDashboard();
            mostrarNotificacion('📅 Turno agendado', 'success');
        }

        function limpiarFormTurno() {
            document.getElementById('turn-pac').value = '';
            document.getElementById('turn-hora').value = '';
            document.getElementById('turn-prof').value = '';
            document.getElementById('turn-serv').value = '';
        }

        // ASISTENCIAS
        function cargarTurnosAsistencia() {
            const pacId = document.getElementById('asi-pac').value;
            if (!pacId) return;

            const turnosPac = turnos.filter(t => t.pacienteId == pacId);
            if (turnosPac.length > 0) {
                document.getElementById('asi-fecha').value = turnosPac[0].fecha;
            }
        }

        function agregarAsistencia() {
            const pac = document.getElementById('asi-pac').value;
            const fecha = document.getElementById('asi-fecha').value;
            const dur = document.getElementById('asi-dur').value;
            const est = document.getElementById('asi-est').value;
            const notas = document.getElementById('asi-notas').value;

            if (!pac || !fecha) {
                alert('Completa paciente y fecha');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            asistencias.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                fecha,
                duracion: dur,
                estado: est,
                notas
            });

            localStorage.setItem('asistencias', JSON.stringify(asistencias));
            limpiarFormAsistencia();
            actualizarTablas();
            actualizarDashboard();
            mostrarNotificacion('✓ Asistencia registrada', 'success');
        }

        function limpiarFormAsistencia() {
            document.getElementById('asi-pac').value = '';
            document.getElementById('asi-dur').value = '45';
            document.getElementById('asi-est').value = 'Presente';
            document.getElementById('asi-notas').value = '';
        }

        // HISTORIAS CLÍNICAS
        function agregarHistoria() {
            const pac = document.getElementById('his-pac').value;
            const prof = document.getElementById('his-prof').value;
            const diag = document.getElementById('his-diag').value;
            const eval = document.getElementById('his-eval').value;

            if (!pac || !prof) {
                alert('Completa paciente y profesional');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            historias.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                profesional: prof,
                diagnostico: diag,
                evaluacion: eval,
                archivo: null,
                fecha: new Date().toISOString().split('T')[0]
            });

            localStorage.setItem('historias', JSON.stringify(historias));
            limpiarFormHistoria();
            actualizarTablas();
            actualizarDashboard();
            mostrarNotificacion('📊 Historia guardada', 'success');
        }

        function limpiarFormHistoria() {
            document.getElementById('his-pac').value = '';
            document.getElementById('his-prof').value = '';
            document.getElementById('his-diag').value = '';
            document.getElementById('his-eval').value = '';
        }

        function handleDragOver(e) {
            e.preventDefault();
            document.getElementById('fileUpload').classList.add('dragover');
        }

        function handleDragLeave(e) {
            document.getElementById('fileUpload').classList.remove('dragover');
        }

        function handleDrop(e) {
            e.preventDefault();
            document.getElementById('fileUpload').classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFileSelect({ target: { files } });
            }
        }

        function handleFileSelect(e) {
            const file = e.target.files[0];
            if (file) {
                const validTypes = ['application/pdf', 'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
                if (!validTypes.includes(file.type)) {
                    mostrarNotificacion('❌ Solo PDF o Word', 'warning');
                    return;
                }

                document.getElementById('fileMensaje').innerHTML = `<div class="notification notification-success">✓ Archivo: ${file.name} cargado</div>`;
                // Aquí iría la lógica de guardar el archivo
            }
        }

        // FACTURACIÓN
        function calcularTotal() {
            const ses = parseInt(document.getElementById('fact-ses').value) || 0;
            const val = parseFloat(document.getElementById('fact-val').value) || 0;
            document.getElementById('fact-tot').value = (ses * val).toFixed(2);
        }

        function agregarFactura() {
            const per = document.getElementById('fact-per').value;
            const pac = document.getElementById('fact-pac').value;
            const val = parseFloat(document.getElementById('fact-val').value);
            const tot = parseFloat(document.getElementById('fact-tot').value);

            if (!per || !pac || !val) {
                alert('Completa período, paciente y valor');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            const sesionesDelPeriodo = asistencias.filter(a => a.pacienteId == pac && a.fecha.startsWith(per) && a.estado === 'Presente').length;

            facturas.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                periodo: per,
                sesiones: sesionesDelPeriodo,
                valor: val,
                total: (sesionesDelPeriodo * val).toFixed(2),
                estado: 'Pendiente'
            });

            localStorage.setItem('facturas', JSON.stringify(facturas));
            limpiarFormFactura();
            actualizarTablas();
            actualizarDashboard();
            mostrarNotificacion('💾 Factura creada', 'success');
        }

        function limpiarFormFactura() {
            document.getElementById('fact-pac').value = '';
            document.getElementById('fact-ses').value = '0';
            document.getElementById('fact-val').value = '500';
            document.getElementById('fact-tot').value = '';
        }

        // MENSAJES WHATSAPP
        function enviarMensaje() {
            const pac = document.getElementById('msg-pac').value;
            const tipo = document.getElementById('msg-tipo').value;
            const texto = document.getElementById('msg-texto').value;

            if (!pac || !tipo || !texto) {
                alert('Completa todos los campos');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            mensajes.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                tipo,
                canal: 'WhatsApp',
                mensaje: texto,
                fecha: new Date().toISOString().split('T')[0],
                estado: 'Enviado'
            });

            localStorage.setItem('mensajes', JSON.stringify(mensajes));
            limpiarFormMensaje();
            actualizarTablas();
            mostrarNotificacion('💬 Mensaje enviado por WhatsApp', 'success');
        }

        function enviarEmail() {
            const pac = document.getElementById('msg-pac').value;
            const tipo = document.getElementById('msg-tipo').value;
            const texto = document.getElementById('msg-texto').value;

            if (!pac || !tipo || !texto) {
                alert('Completa todos los campos');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            mensajes.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                tipo,
                canal: 'Email',
                mensaje: texto,
                fecha: new Date().toISOString().split('T')[0],
                estado: 'Enviado'
            });

            localStorage.setItem('mensajes', JSON.stringify(mensajes));
            limpiarFormMensaje();
            actualizarTablas();
            mostrarNotificacion('📧 Mensaje enviado por Email', 'success');
        }

        function limpiarFormMensaje() {
            document.getElementById('msg-pac').value = '';
            document.getElementById('msg-tipo').value = '';
            document.getElementById('msg-texto').value = '';
        }

        // TAREAS
        function agregarTarea() {
            const pac = document.getElementById('tarea-pac').value;
            const tipo = document.getElementById('tarea-tipo').value;
            const desc = document.getElementById('tarea-desc').value;
            const dur = document.getElementById('tarea-dur').value;
            const freq = document.getElementById('tarea-freq').value;

            if (!pac || !tipo || !desc) {
                alert('Completa todos los campos obligatorios');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            tareas.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                tipo,
                descripcion: desc,
                duracion: dur,
                frecuencia: freq,
                fecha: new Date().toISOString().split('T')[0],
                estado: 'Activa'
            });

            localStorage.setItem('tareas', JSON.stringify(tareas));
            limpiarFormTarea();
            actualizarTablas();
            actualizarDashboard();
            mostrarNotificacion('✔️ Tarea asignada', 'success');
        }

        function limpiarFormTarea() {
            document.getElementById('tarea-pac').value = '';
            document.getElementById('tarea-tipo').value = '';
            document.getElementById('tarea-desc').value = '';
            document.getElementById('tarea-dur').value = '15';
            document.getElementById('tarea-freq').value = 'Diaria';
        }

        // PAGOS
        function agregarPago() {
            const pac = document.getElementById('pago-pac').value;
            const monto = parseFloat(document.getElementById('pago-monto').value);
            const fecha = document.getElementById('pago-fecha').value;
            const metodo = document.getElementById('pago-metodo').value;
            const obs = document.getElementById('pago-obs').value;

            if (!pac || !monto || !fecha || !metodo) {
                alert('Completa todos los campos obligatorios');
                return;
            }

            const paciente = pacientes.find(p => p.id == pac);
            pagos.push({
                id: Date.now(),
                pacienteId: pac,
                pacienteNombre: paciente.nombre,
                monto: monto.toFixed(2),
                fecha,
                metodo,
                observaciones: obs
            });

            localStorage.setItem('pagos', JSON.stringify(pagos));
            limpiarFormPago();
            actualizarTablas();
            actualizarDashboard();
            mostrarNotificacion('💳 Pago registrado', 'success');
        }

        function limpiarFormPago() {
            document.getElementById('pago-pac').value = '';
            document.getElementById('pago-monto').value = '';
            document.getElementById('pago-metodo').value = '';
            document.getElementById('pago-obs').value = '';
        }

        // ACTUALIZAR TABLAS
        function actualizarTablas() {
            // Pacientes
            let html = '';
            pacientes.forEach(p => {
                html += `<tr><td>${p.nombre}</td><td>${p.dni}</td><td>${p.tel || '-'}</td><td>${p.os || '-'}</td><td><button class="btn-danger btn-small" onclick="eliminar('pacientes', ${p.id})">Eliminar</button></td></tr>`;
            });
            document.getElementById('corpoPacientes').innerHTML = html || '<tr><td colspan="5" style="text-align: center; color: #999;">No hay pacientes</td></tr>';

            // Turnos
            html = '';
            turnos.forEach(t => {
                html += `<tr><td>${t.fecha}</td><td>${t.hora}</td><td>${t.pacienteNombre}</td><td>${t.profesional}</td><td>${t.servicio}</td><td><span class="badge badge-info">${t.estado}</span></td><td><button class="btn-danger btn-small" onclick="eliminar('turnos', ${t.id})">Eliminar</button></td></tr>`;
            });
            document.getElementById('corpoTurnos').innerHTML = html || '<tr><td colspan="7" style="text-align: center; color: #999;">No hay turnos</td></tr>';

            // Asistencias
            html = '';
            asistencias.forEach(a => {
                html += `<tr><td>${a.fecha}</td><td>${a.pacienteNombre}</td><td>${a.duracion} min</td><td><span class="badge ${a.estado === 'Presente' ? 'badge-success' : 'badge-danger'}">${a.estado}</span></td><td>${a.notas || '-'}</td></tr>`;
            });
            document.getElementById('corpoAsistencias').innerHTML = html || '<tr><td colspan="5" style="text-align: center; color: #999;">No hay asistencias</td></tr>';

            // Historias
            html = '';
            historias.forEach(h => {
                html += `<tr><td>${h.pacienteNombre}</td><td>${h.profesional}</td><td>${h.fecha}</td><td>${h.archivo || '-'}</td><td><button class="btn-danger btn-small" onclick="eliminar('historias', ${h.id})">Eliminar</button></td></tr>`;
            });
            document.getElementById('corpoHistorias').innerHTML = html || '<tr><td colspan="5" style="text-align: center; color: #999;">No hay historias</td></tr>';

            // Facturas
            html = '';
            facturas.forEach(f => {
                html += `<tr><td>${f.periodo}</td><td>${f.pacienteNombre}</td><td>${f.sesiones}</td><td>$${f.total}</td><td><span class="badge badge-warning">${f.estado}</span></td><td><button class="btn-danger btn-small" onclick="eliminar('facturas', ${f.id})">Eliminar</button></td></tr>`;
            });
            document.getElementById('corpoFacturas').innerHTML = html || '<tr><td colspan="6" style="text-align: center; color: #999;">No hay facturas</td></tr>';

            // Mensajes
            html = '';
            mensajes.forEach(m => {
                html += `<tr><td>${m.fecha}</td><td>${m.pacienteNombre}</td><td>${m.tipo}</td><td>${m.canal}</td><td><span class="badge badge-success">${m.estado}</span></td></tr>`;
            });
            document.getElementById('corpoMensajes').innerHTML = html || '<tr><td colspan="5" style="text-align: center; color: #999;">No hay mensajes</td></tr>';

            // Tareas
            html = '';
            tareas.forEach(t => {
                html += `<tr><td>${t.pacienteNombre}</td><td>${t.tipo}</td><td>${t.descripcion.substring(0, 30)}...</td><td>${t.frecuencia}</td><td>${t.fecha}</td><td><span class="badge badge-success">${t.estado}</span></td></tr>`;
            });
            document.getElementById('corpoTareas').innerHTML = html || '<tr><td colspan="6" style="text-align: center; color: #999;">No hay tareas</td></tr>';

            // Pagos
            html = '';
            pagos.forEach(p => {
                html += `<tr><td>${p.fecha}</td><td>${p.pacienteNombre}</td><td>$${p.monto}</td><td>${p.metodo}</td><td>${p.observaciones || '-'}</td></tr>`;
            });
            document.getElementById('corpoPagos').innerHTML = html || '<tr><td colspan="5" style="text-align: center; color: #999;">No hay pagos</td></tr>';
        }

        // DASHBOARD
        function actualizarDashboard() {
            document.getElementById('stat-pac').textContent = pacientes.length;
            document.getElementById('stat-turn').textContent = turnos.length;
            document.getElementById('stat-asi').textContent = asistencias.length;
            const totalPagos = pagos.reduce((s, p) => s + parseFloat(p.monto), 0);
            document.getElementById('stat-pag').textContent = '$' + totalPagos.toFixed(2);
            document.getElementById('stat-his').textContent = historias.length;
            document.getElementById('stat-tar').textContent = tareas.length;
        }

        // UTILIDADES
        function eliminar(tipo, id) {
            if (!confirm('¿Confirmar eliminación?')) return;

            if (tipo === 'pacientes') pacientes = pacientes.filter(p => p.id !== id);
            else if (tipo === 'turnos') turnos = turnos.filter(t => t.id !== id);
            else if (tipo === 'historias') historias = historias.filter(h => h.id !== id);
            else if (tipo === 'facturas') facturas = facturas.filter(f => f.id !== id);

            localStorage.setItem(tipo, JSON.stringify(eval(tipo)));
            cargarSelects();
            actualizarTablas();
            actualizarDashboard();
        }

        function mostrarNotificacion(msg, tipo) {
            const div = document.createElement('div');
            div.className = `notification notification-${tipo}`;
            div.textContent = msg;
            div.style.position = 'fixed';
            div.style.top = '20px';
            div.style.right = '20px';
            div.style.zIndex = '9999';
            document.body.appendChild(div);
            setTimeout(() => div.remove(), 3000);
        }
    </script>
</body>
</html>
